-- copyright/exclusions.json --
[
  "web/internal/hashfs/*.go",
  "web/internal/unionfs/*.go",
  "rr/*.go",
  "txtar/txtar.go",
  "web/debug*.go",
  "web/internal/components/*_templ.go"
]
